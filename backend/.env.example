# ── Authentication ────────────────────────────────────────────────
# Change these before deploying! Use a long random string for JWT_SECRET.
JWT_SECRET=replace_with_a_long_random_secret_string
ADMIN_PASSWORD=replace_with_your_admin_password
EXPORT_SECRET=replace_with_your_export_secret

# ── Study link (your public URL) ──────────────────────────────────
# Used in share emails and CORS allow-list.
STUDY_LINK=https://your-deployed-url.railway.app

# ── Email (Gmail SMTP) ────────────────────────────────────────────
# Create a Gmail App Password at:
#   Google Account → Security → 2-Step Verification → App passwords
# Set DEV_MODE= (empty) to actually send emails.
# Set DEV_MODE=true to print OTPs to console instead.
SMTP_EMAIL=yourname@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
DEV_MODE=
